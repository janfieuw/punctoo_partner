########################################
# DATABASE
########################################

# PostgreSQL connection string
# voorbeeld:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/punctoo_partner"


########################################
# INTERNAL SYNC (MyPunctoo ↔ Partner)
########################################

# Secret dat MyPunctoo gebruikt om veilig te communiceren
# MOET identiek zijn in beide apps
INTERNAL_SYNC_SECRET="change-this-to-a-very-strong-secret"


########################################
# PARTNER APP BASE URL (optioneel)
########################################

# Handig voor absolute URLs (bv mails later)
APP_URL="http://localhost:3000"


########################################
# AUTH / SESSION
########################################

# Secret voor session/cookies (optioneel nu, maar future-proof)
AUTH_SECRET="another-long-random-secret"


########################################
# SYNC CONFIG IN MYPUNCTOO (TER INFO)
########################################

# Deze variabelen horen NIET in deze app,
# maar in MyPunctoo — toch handig als referentie:

# PARTNER_SYNC_URL="https://partner.punctoo.be/api/internal/company-status"
# PARTNER_SYNC_SECRET="zelfde-als-hierboven"